# =================================================================
# 1. STM32CubeMX 相关 (保留 .ioc 和 .mxproject)
# =================================================================
# 忽略 CubeMX 生成的备份文件
*.bak
*.tmp
/backup/
/MDK-ARM/RTE/
/MDK-ARM/DebugConfig/

# =================================================================
# 2. Keil MDK-ARM 工程文件 (只保留 .uvprojx)
# =================================================================
# 忽略用户特定的布局配置 (窗口位置、打开的文件等)
*.uvguix.*
*.uvoptx
*.uvopt

# 忽略 J-Link / ST-Link 产生的日志和配置
JLinkLog.txt
JLinkSettings.ini
*.scvd
*.ini

# =================================================================
# 3. 编译中间文件
# =================================================================
*.o
*.d
*.crf
*.dep
*.i
*.iex
*.lnp
*.lst
*.m51
*.m52
*.map
*.sct
*.htm
*.build_log.htm
*_Data/

# =================================================================
# 4. 编译输出文件 (可执行/烧录文件)
# =================================================================
*.axf
*.elf
*.hex
*.bin
*.lib

# =================================================================
# 5. 编辑器辅助文件 (VSCode / SourceInsight)
# =================================================================
.vscode/
.bs4/
*.code-workspace
*.si4project/

# =================================================================
# 6. 操作系统垃圾文件
# =================================================================
.DS_Store
Thumbs.db